sui-text-primary">Return Policy</h4></div></div><div class="sui-flex sui-flex-col sui-grow sui-justify-between"><div class="sui-mb-4">You can return your appliance for damages and defects within 48 hours.</div><a href="https://www.homedepot.com/c/Return_Policy" class="sui-font-regular sui-text-base sui-tracking-normal sui-normal-case sui-line-clamp-unset sui-font-normal sui-text-primary focus-visible:sui-bg-focus focus-visible:sui-outline-none sui-underline" target="_blank">Return Policy</a></div></div></div></div></div><div class="sui-flex"><div class="sui-paper sui-paper-outlined sui-rounded-base sui-flex sui-flex-grow"><div class="sui-flex sui-overflow-hidden sui-p-4 sui-gap-4 sui-flex-col sui-grow"><div class="sui-flex sui-flex-col sui-grow sm:sui-min-w-full"><div class="sui-flex sui-flex-row sui-mb-4"><div class="sui-my-auto"><svg class="sui-inline-block sui-align-baseline sui-fill-current sui-w-8 sui-h-8" viewBox="0 0 24 24" focusable="false" aria-hidden="true" data-testid="SavingsIcon"><path d="m8.625 16.216 6.841-6.841-1.591-1.591-6.841 6.841 1.591 1.591ZM7.5 11.25a1.5 1.5 0 1 0 0-3 1.5 1.5 0 0 0 0 3Zm9 3.75a1.5 1.5 0 1 1-3 0 1.5 1.5 0 0 1 3 0Z"></path><path d="M18 3.554V.289l-1.497.524-.004.002-.009.003-.032.011a20.39 20.39 0 0 0-.541.2c-.352.135-.834.325-1.352.55-.516.225-1.08.49-1.593.772-.345.19-.705.41-1.019.652-1.87.03-4.66.28-7.079 1.529-1.322.683-2.556 1.676-3.454 3.109C.52 9.076 0 10.883 0 13.125c0 2.618.606 4.484 1.253 5.724a7.687 7.687 0 0 0 .997 1.483V24h5.57l1.125-2.25h3.86L13.93 24h5.57v-3.74a6.94 6.94 0 0 0 .726-.877c.474-.674.98-1.624 1.309-2.883H24V8.25h-1.874c-.369-.768-.916-1.602-1.552-2.37-.712-.86-1.596-1.711-2.574-2.326Zm-1.125-1.679L16.503.813l.372 1.062Zm-1.413 1.768c.097-.043.194-.084.288-.123v1.383l.621.311c.848.425 1.727 1.204 2.47 2.1.746.902 1.266 1.813 1.467 2.416l.256.77h1.186v3.75h-2.078l-.157.94c-.228 1.374-.72 2.315-1.13 2.9-.206.293-.394.5-.522.625a2.548 2.548 0 0 1-.164.15l-.449.33v2.555h-1.93l-1.125-2.25h-6.64L6.43 21.75H4.5v-2.402l-.396-.33a2.908 2.908 0 0 1-.218-.235 5.447 5.447 0 0 1-.639-.975c-.478-.917-.997-2.426-.997-4.683 0-1.883.433-3.263 1.076-4.29.645-1.028 1.544-1.769 2.58-2.304 2.112-1.09 4.698-1.281 6.469-1.281h.466l.33-.33c.143-.143.44-.352.888-.599.428-.236.923-.47 1.403-.678Z"></path></svg></div><div class="sui-ml-4"><h4 class="sui-h4-bold sui-line-clamp-unset sui-font-normal sui-text-primary">Price Match</h4><h4 class="sui-h4-bold sui-line-clamp-unset sui-font-normal sui-text-primary">Guarantee</h4></div></div><div class="sui-flex sui-flex-col sui-grow sui-justify-between"><div class="sui-mb-4">We will match prices including shipping of any other online competitor.</div><a href="https://www.homedepot.com/c/PM_New_Lower_Price" class="sui-font-regular sui-text-base sui-tracking-normal sui-normal-case sui-line-clamp-unset sui-font-normal sui-text-primary focus-visible:sui-bg-focus focus-visible:sui-outline-none sui-underline" target="_blank">Learn More</a></div></div></div></div></div></div></div></div><div data-fusion-slot="slotG11" data-fusion-component="@thd-olt-component-react/delivery-and-installation" class="fusion-slot empty:sui-hidden sui-bg-primary sui-mb-3"><div class="delivery-and-installation" data-component="delivery-and-installation:DeliveryAndInstallation:v5.3.0"><div class="educational-summary" data-component="educational-summary:EducationalSummary:v10.4.0"><div class="desktop-items"><div class="educational-summary__header"><div class="_section-heading_1rqgr_1"><div class="_section-heading__title_1rqgr_45"><h2 class="_section-heading__text_1rqgr_21">Delivery and Installation</h2></div></div></div><div class="grid"><div class="educational-summary__desktop-view col__12-12" style="padding: 0px;"><div class="educational-summary__desktop-view--container--wrap-sooner col__12-12 col__6-12--xs col__6-12--sm" style="padding: 0px;"><div class="educational-summary__item-wrapper educational-summary__item-wrapper--details"><div class="educational-summary__video col__12-12 col__12-12--xs"><div class="_video-player__container_7wx5c_1" data-component="video-player:VideoStill:v5.3.0" style="width: 300px; max-width: 300px;"><div class="_video-player__wrapper_7wx5c_47 _video-player__wrapper--still_7wx5c_51"><img src="./IMG_2777_files/image(1).jpg" alt="thumbnail" class="" height="150" width="300" loading="lazy"><button alt="Play Button" aria-label="play video" class="_video-player__play-button_7wx5c_12" type="button"></button></div></div></div><div class="col__12-12 col__12-12--xs" style="padding: 0px;"><div class="educational-info"><div class="educational-info__container educational-info__container--multi-view"><div class="educational-info__title">Home Depot Dryer Delivery &amp; Installation</div><div class="educational-info__description">This video will walk you through the simple steps you must take in order to ensure a successful delivery and installation of your new Dryer from The Home Depot.</div><div class="educational-info__link"><a href="http://www.homedepot.com/c/Appliance_Delivery_Installation">LEARN MORE ABOUT DELIVERY &amp; INSTALLATION</a></div></div></div></div></div><div class="educational-summary__item-wrapper educational-summary__item-wrapper--details"><div class="educational-summary__video col__12-12 col__12-12--xs"><div class="_video-player__container_7wx5c_1" data-component="video-player:VideoStill:v5.3.0" style="width: 300px; max-width: 300px;"><div class="_video-player__wrapper_7wx5c_47 _video-player__wrapper--still_7wx5c_51"><img src="./IMG_2777_files/image(2).jpg" alt="thumbnail" class="" height="150" width="300" loading="lazy"><button alt="Play Button" aria-label="play video" class="_video-player__play-button_7wx5c_12" type="button"></button></div></div></div><div class="col__12-12 col__12-12--xs" style="padding: 0px;"><div class="educational-info"><div class="educational-info__container educational-info__container--multi-view"><div class="educational-info__title">Washer and Dryer Dimensions </div><div class="educational-info__description">Taking accurate measurements in your home is critical when purchasing a new washer and dryer.  Here are step by step instructions on how to do it correctly.</div><div class="educational-info__link"><a href="http://www.homedepot.com/b/Appliances-Washers-Dryers/N-5yc1vZc3ol">SHOP ALL WASHERS &amp; DRYERS</a></div></div></div></div></div></div><div class="col__12-12 col__6-12--xs col__6-12--sm" style="padding: 0px;"><div class="educational-summary__details--container"><div class="additional-details"><div class="delivery-and-installation-details" data-testid="delivery-and-installation-details-test-id"><h2 class="delivery-and-installation-details__header">Please ensure the following prior to delivery:</h2><ul class="delivery-and-installation-details__text"><li class="delivery-and-installation-details__appliance-text">A new electrical cord</li><li class="delivery-and-installation-details__appliance-text">A 240V electric outlet within 4 ft. of hookup</li><li class="delivery-and-installation-details__appliance-text">Verify that your outlet type matches the approved types shown above</li><li class="delivery-and-installation-details__appliance-text">Empty &amp; unplug your old appliance</li></ul></div></div></div></div></div></div></div></div></div></div><div data-fusion-slot="slotG12" data-fusion-component="@thd-olt-component-react/thd-recs-containers" class="fusion-slot empty:sui-hidden"></div><div data-fusion-slot="slotG13" data-fusion-component="@thd-olt-component-react/thd-recs-containers" class="fusion-slot empty:sui-hidden"><section id="recs_pip_alternatives" class="grid"><div class="zone-card"></div></section></div><div data-fusion-slot="slotG14" data-fusion-component="@thd-olt-component-react/retail-media-pla-sponsored-placements" class="fusion-slot empty:sui-hidden"><section id="sponsored-carousel" class="grid"></section></div><div data-fusion-slot="slotG15" data-fusion-component="@thd-olt-component-react/feature-based-recommendatio