    <script>
        window.__APOLLO_STATE__={"ROOT_QUERY":{"__typename":"Query","reviews({\"filters\":{\"isVerifiedPurchase\":false,\"prosCons\":null,\"starRatings\":null},\"itemId\":\"323095575\",\"searchTerm\":null,\"sortBy\":\"photoreview\",\"startIndex\":1})":{"__typename":"ReviewsResponse","Results":[{"__typename":"ReviewModel","AuthorId":"0630496B9391ABBF0S","Badges":{"__typename":"ReviewsBadges","DIY":null,"top250Contributor":null,"IncentivizedReview":null,"EarlyReviewerIncentive":null,"top1000Contributor":null,"VerifiedPurchaser":null},"BadgesOrder":["verifiedPurchaser"],"CampaignId":"msg_email-_-PR1_OUT-_-20260318_Product_Review_4683752-_-Mobile-_-EM-_-1","ContextDataValues":{"__typename":"ReviewsContextDataValues","Age":null,"VerifiedPurchaser":null},"ContextDataValuesOrder":["EarlyReviewerIncentive"],"Id":"299487686","IsRecommended":null,"IsSyndicated":false,"Photos":[{"__typename":"ReviewPhoto","Id":"22149880","Sizes":{"__typename":"ReviewPhotoSizes","normal":{"__typename":"ReviewPhotoSize","Url":"https://photos-us.bazaarvoice.com/photo/2/cGhvdG86aG9tZWRlcG90/987d36b0-476b-5272-ad1b-da71864087ef"},"thumbnail":{"__typename":"ReviewPhotoSize","Url":"https://photos-us.bazaarvoice.com/photo/2/cGhvdG86aG9tZWRlcG90/b06d3357-66e0-5c50-adcc-afb54cdece38"}}}],"ProductId":"323095575","SubmissionTime":"2026-03-18T16:55:11.000+00:00","TagDimensions":{"__typename":"ReviewsTagDimensions","Pro":null,"Con":null},"Title":null,"TotalNegativeFeedbackCount":0,"TotalPositiveFeedbackCount":0,"ClientResponses":[],"Rating":5,"RatingRange":5,"ReviewText":"The Samsung compact washer and dryer is an excellent laundry combo for tight spaces. Both units provide plenty of space for the cleaning needs of 1-2 people. The multiple settings accommodate all laundry types, and it's a breeze to use. While I don't recommend stuffing your comforter (take those to a dry cleaner or use an industrial machine), for everything else it's great. \r\n\r\nI also had the Home Depot team picknup my old machine and install the new ones. The delivery and installation teams I worked with were great: punctual, communicative, efficient, and pleasant.","SecondaryRatings":{"__typename":"SecondaryRatings","Quality":null,"Value":null,"EnergyEfficiency":null,"Features":null,"Appearance":null,"EaseOfInstallation":null,"EaseOfUse":null},"SecondaryRatingsOrder":["CustomerService","Delivery"],"SyndicationSource":null,"UserNickname":"CHRIS","UserLocation":null,"Videos":[],"OriginalProductName":"24 in. 4.0 cu. ft. Vented Smart Dial Electric Dryer in White with Sensor Dry"},{"__typename":"ReviewModel","AuthorId":"zlyrot446s4mctcwbjpsfglepb","Badges":{"__typename":"ReviewsBadges","DIY":null,"top250Contributor":null,"IncentivizedReview":null,"EarlyReviewerIncentive":null,"top1000Contributor":null,"VerifiedPurchaser":null},"BadgesOrder":[],"CampaignId":null,"ContextDataValues":{"__typename":"ReviewsContextDataValues","Age":null,"VerifiedPurchaser":null},"ContextDataValuesOrder":[],"Id":"248749183","IsRecommended":null,"IsSyndicated":true,"Photos":[{"__typename":"ReviewPhoto","Id":"16642595","Sizes":{"__typename":"ReviewPhotoSizes","normal":{"__typename":"ReviewPhotoSize","Url":"https://photos-us.bazaarvoice.com/photo/2/cGhvdG86c2Ftc3VuZw/bbe443d5-ea3c-57e5-ac38-829c7fe90431"},"thumbnail":{"__typename":"ReviewPhotoSize","Url":"https://photos-us.bazaarvoice.com/photo/2/cGhvdG86c2Ftc3VuZw/5116ad8e-a316-5d04-b0db-db2111508088"}}}],"ProductId":"323095575","SubmissionTime":"2026-03-13T23:02:47.000+00:00","TagDimensions":{"__typename":"ReviewsTagDimensions","Pro":null,"Con":null},"Title":"Samsung washer combo","TotalNegativeFeedbackCount":0,"TotalPositiveFeedbackCount":0,"ClientResponses":[],"Rating":5,"RatingRange":5,"ReviewText":"[This review was collected as part of a promotion.] We love our washer, dryer combo, priced well and very efficient. I highly recommend getting the Samsung washer combo.","SecondaryRatings":{"__typename":"SecondaryRatings","Quality":null,"Value":{"__typename":"ReviewsQualityRating","Label":"Value","Value":5},"EnergyEfficiency":null,"Features":{"__typename":"ReviewsQualityRating","Label":"Features","Value":5},"Appearance":null,"EaseOfInstallation":null,"EaseOfUse":null},"SecondaryRatingsOrder":["Features","Value"],"SyndicationSource":{"__typename":"SyndicationSource","LogoImageUrl":"https://photos-us.bazaarvoice.com/photo/2/cGhvdG86YXR0cmlidXRpb25sb2dvMg/3f0db944-7f1f-456d-ac37-2291be7453fa","Name":"Samsung US","ContentLink":"https://www.samsung.com/us/laundry/dryers/ventless-4-0-cu-ft-heat-pump-dryer-with-ai-smart-dial-and-wi-fi-connectivity-in-white-sku-dv25b6900hw-a2"},"UserNickname":"Sturat","UserLocation":"Fort Lauderdale, Florida","Videos":[],"OriginalProductName":"Front Load Ventless Heat Pump Dryer"},{"__typename":"ReviewModel","AuthorId":"z309rl4yjxq4ym6hi4m9t0gmrj","Badges":{"__typename":"ReviewsBadges","DIY":null,"top250Contributor":null,"IncentivizedReview":null,"EarlyReviewerIncentive":null,"top1000Contributor":null,"VerifiedPurchaser":null},"BadgesOrder":[],"CampaignId":null,"ContextDataValues":{"__typename":"ReviewsContextDataValues","Age":null,"VerifiedPurchaser":null},"ContextDataValuesOrder":[],"Id":"244672521","IsRecommended":true,"IsSyndicated":true,"Photos":[{"__typename":"ReviewPhoto","Id":"14847820","Sizes":{"__typename":"ReviewPhotoSizes","normal":{"__typename":"ReviewPhotoSize","Url":"https://photos-us.bazaarvoice.com/photo/2/cGhvdG86c2Ftc3VuZw/82499a99-81e3-50ae-aed3-3a65021e8bc5"},"thumbnail":{"__typename":"ReviewPhotoSize","Url":"https://photos-us.bazaarvoice.com/photo/2/cGhvdG86c2Ftc3VuZw/a224e571-7363-5bbd-a683-fde93f768344"}}}],"ProductId":"323095575","SubmissionTime":"2025-09-15T15:47:29.000+00:00","TagDimensions":{"__typename":"ReviewsTagDimensions","Pro":null,"Con":null},"Title":"Capable dryer","TotalNegativeFeedbackCount":0,"TotalPositiveFeedbackCount":0,"ClientResponses":[],"Rating":4,"RatingRange":5,"ReviewText":"[This review was collected as part of a promotion.] Pairs beautifully with the Samsung washer\nGiving 4 stars because I’d really prefer gas but not available in this size.\nElectric dryers are slower ….","SecondaryRatings":{"__typename":"SecondaryRatings","Quality":null,"Value":{"__typename":"ReviewsQualityRating","Label":"Value","Value":5},"EnergyEfficiency":null,"Features":{"__typename":"ReviewsQualityRating","Label":"Features","Value":5},"Appearance":null,"EaseOfInstallation":null,"EaseOfUse":null},"SecondaryRatingsOrder":["Features","Value"],"SyndicationSource":{"__typename":"SyndicationSource","LogoImageUrl":"https://photos-us.bazaarvoice.com/photo/2/cGhvdG86YXR0cmlidXRpb25sb2dvMg/3f0db944-7f1f-456d-ac37-2291be7453fa","Name":"Samsung US","ContentLink":"https://www.samsung.com/us/laundry/dryers/ventless-4-0-cu-ft-heat-pump-dryer-with-ai-smart-dial-and-wi-fi-connectivity-in-white-sku-dv25b6900ew-a2"},"UserNickname":"ADMOORE","UserLocation":"Phishing Beach, CA","Videos":[],"OriginalProductName":"Front Load Electric Dryer"},{"__typename":"ReviewModel","AuthorId":"zsnu0qlzo4youp9ykdokpegh51","Badges":{"__typename":"ReviewsBadges","DIY":null,"top250Contributor":null,"IncentivizedReview":null,"EarlyReviewerIncentive":null,"top1000Contributor":null,"VerifiedPurchaser":null},"BadgesOrder":[],"CampaignId":null,"ContextDataValues":{"__typename":"ReviewsContextDataValues","Age":null,"VerifiedPurchaser":null},"ContextDataValuesOrder":[],"Id":"243099338","IsRecommended":false,"IsSyndicated":true,"Photos":[{"__typename":"ReviewPhoto","Id":"14233751","Sizes":{"__typename":"ReviewPhotoSizes","normal":{"__typename":"ReviewPhotoSize","Url":"https://photos-us.bazaarvoice.com/photo/2/cGhvdG86c2Ftc3VuZw/b3969f5e-71e7-50eb-a407-39392a88dabd"},"thumbnail":{"__typename":"ReviewPhotoSize","Url":"https://photos-us.bazaarvoice.com/photo/2/cGhvdG86c2Ftc3VuZw/94bcba9e-e69d-523c-8e20-d6cf4ace53b4"}}}],"ProductId":"323095575","SubmissionTime":"2025-07-06T02:46:10.000+00:00","TagDimensions":{"__typename":"ReviewsTagDimensions","Pro":null,"Con":null},"Title":"\"Ventless\" marketing is a scam","TotalNegativeFeedbackCount":0,"TotalPositiveFeedbackCount":0,"ClientResponses":[{"__typename":"ClientResponse","Response":"Good day,\n\nWe understand where you're coming from and how you feel about this experience. Your laundry experience matters to us.\n\nThis guide will walk you through the steps to enhance the dryer's drying ability, especially if it takes too long to dry the clothes. Learn more from the embedded links.\n\nClothes are not dry after using the Samsung dryer:\nhttps://www.samsung.com/us/support/troubleshoot/TSG10001001/#dryer-cycle-takes-too-long\n\nFor optimal performance and comfort, the dryer should be used in a well-ventilated area. If relocation is not possible, ensure adequate airflow by opening a window or keeping the room door open during operation to help dissipate excess heat. \n\nShould you require further assistance, please feel free to get back to us via the following options:\n\n1. Facebook Messenger: http://m.me/samsungsupport\n2. Twitter: https://twitter.com/messages/compose?recipient_id=18768513\n3. Samsung Community: https://us.community.samsung.com/t5/Samsung-Community/ct-p/us\n\nWhen you message us, please provide us with this reference number 1149875022, to help our team pull up your information.\n\nHave a great day!\n\n^Chrystel","Date":"2025-07-07T13:51:32.000+00:00","Department":"SEA CARE"}],"Rating":1,"RatingRange":5,"ReviewText":"Did it dry my clothes? Yes. But it took 2 hours. It also heated my bathroom. After drying a full load in two hours, my bathroom (medium-size approx. 8' by 7') would heat up by 15 degrees. While these are marketed as \"ventless\" because there is no vent that pumps the hot air out using ducting, there are heat vents on the back of the dryer that let out hot air into your room (picture included). And because you can't use ducting to vent the hot air outside, it just heats up your room. The marketing claims the hot air is recycled in the heat pump cycle, and that's how it creates energy efficiency and doesn't require venting. But my experience in reality, is that it turned my bathroom into a sauna.","SecondaryRatings":{"__typename":"SecondaryRatings","Quality":null,"Value":{"__typename":"ReviewsQualityRating","Label":"Value","Value":1},"EnergyEfficiency":null,"Features":{"__typename":"ReviewsQualityRating","Label":"Features","Value":2},"Appearance":null,"EaseOfInstallation":null,"EaseOfUse":null},"SecondaryRatingsOrder":["Features","Value"],"SyndicationSource":{"__typename":"SyndicationSource","LogoImageUrl":"https://photos-us.bazaarvoice.com/photo/2/cGhvdG86YXR0cmlidXRpb25sb2dvMg/3f0db944-7f1f-456d-ac37-2291be7453fa","Name":"Samsung US","ContentLink":"https://www.samsung.com/us/laundry/dryers/ventless-4-0-cu-ft-heat-pump-dryer-with-ai-smart-dial-and-wi-fi-connectivity-in-white-sku-dv25b6900hw-a2"},"UserNickname":"annoyedbuyer","UserLocation":"New Hampshire, USA","Videos":[],"OriginalProductName":"Front Load Ventless Heat Pump Dryer"},{"__typename":"ReviewModel","AuthorId":"z6jbml91gm4w5yf7p4elhasxz3","Badges":{"__typename":"ReviewsBadges","DIY":null,"top250Contributor":null,"IncentivizedReview":null,"EarlyReviewerIncentive":null,"top1000Contributor":null,"VerifiedPurchaser":null},"BadgesOrder":[],"CampaignId":"BV_REVIEW_DISPLAY","ContextDataValues":{"__typename":"ReviewsContextDataValues","Age":null,"VerifiedPurchaser":null},"ContextDataValuesOrder":[],"Id":"292283786","IsRecommended":null,"IsSyndicated":false,"Photos":[{"__typename":"ReviewPhoto","Id":"18428477","Sizes":{"__typename":"ReviewPhotoSizes","normal":{"__typename":"ReviewPhotoSize","Url":"https://photos-us.bazaarvoice.com/photo/2/cGhvdG86aG9tZWRlcG90/67b8eb31-8e62-5141-9306-31bbc76a654d"},"thumbnail":{"__typename":"ReviewPhotoSize","Url":"https://photos-us.bazaarvoice.com/photo/2/cGhvdG86aG9tZWRlcG90/ce9f9d65-4b0e-54e0-bcd1-85fde740f7a1"}}}],"ProductId":"323095575","SubmissionTime":"2025-07-03T19:21:36.000+00:00","TagDimensions":{"__typename":"ReviewsTagDimensions","Pro":null,"Con":null},"Title":"Terrible dryer","TotalNegativeFeedbackCount":0,"TotalPositiveFeedbackCount":0,"ClientResponses":[{"__typename":"ClientResponse","Response":"\nWe understand your disappointment about what occurred with the dryer, Mal.\u003cbr />\u003cbr />You may contact our Support Team via the link below to speak with a live representative should you need to follow up on the replacement panel&#39;s status.\u003cbr />\u003cbr />1. Facebook Messenger: http://m.me/samsungsupport \u003cbr />2. Twitter: https://twitter.com/messages/compose?recipient_id&#61;18768513 \u003cbr />3. Samsung Community: https://us.commuity.samsung.com/t5/Samsung-Community/ct-p/us \u003cbr />4. Customer Care: 1-800-726-7864 (1-800-SAMSUNG) \u003cbr />\u003cbr />Thank you.\u003cbr />\u003cbr />-Angelica\n    \u003cimg src=\"https://s3.amazonaws.com/stratos-logos/logos/Samsung.png\" alt=\"Samsung\" title=\"Samsung\" style=\"display: block !important; margin-top: 2em !important; border: 1px solid #ccc !important; padding: 2px !important; background-color: white !important;\" />\n\u003c!--[if ReviewResponse]>\u003c![endif]-->","Date":"2025-07-07T13:32:17.000+00:00","Department":"Samsung"}],"Rating":1,"RatingRange":5,"ReviewText":"We've had this dryer for almost a year and a few months into using it, we realized that the lint was being pulled through the dryer into the back where it sits on the heating element and burns making all our clothes smell like smoke. We've had to pull the back off and remove the lint from the heating element multiple times. We also have to clean the duct out the connects the dryer to the wall duct once a month to make it actually dry our clothes. It seems the lint trap doesn't work and the fan isn't strong enough to push the lint the correct direction. We've been in contact with Samsung about the problem since the beginning of the year. 7 months later, a crazy number of calls and emails back and forth, and onto our third service visit, nothing has been resolved. I would not advise buying this dryer or trying to rely on Samsung customer service.","SecondaryRatings":{"__typename":"SecondaryRatings","Quality":null,"Value":null,"EnergyEfficiency":null,"Features":null,"Appearance":null,"EaseOfInstallation":null,"EaseOfUse":null},"SecondaryRatingsOrder":[],"SyndicationSource":null,"UserNickname":"mal","UserLocation":null,"Videos":[],"OriginalProductName":"24 in. 4.0 cu. ft. Vented Smart Dial Electric Dryer in White with Sensor Dry"},{"__typename":"ReviewModel","AuthorId":"zkwlf6468jyxkfpyfmxqmlr5ll","Badges":{"__typename":"ReviewsBadges","DIY":null,"top250Contributor":null,"IncentivizedReview":null,"EarlyReviewerIncentive":null,"top1000Contributor":null,"VerifiedPurchaser":null},"BadgesOrder":[],"CampaignId":null,"ContextDataValues":{"__typename":"ReviewsContextDataValues","Age":null,"VerifiedPurchaser":null},"ContextDataValuesOrder":[],"Id":"241057555","IsRecommended":null,"IsSyndicated":true,"Photos":[{"__typename":"ReviewPhoto","Id":"13302167","Sizes":{"__typename":"ReviewPhotoSizes","normal":{"__typename":"ReviewPhotoSize","Url":"https://photos-us.bazaarvoice.com/photo/2/cGhvdG86c2Ftc3VuZw/c8d43ae8-4139-543e-ba67-852d22715590"},"thumbnail":{"__typename":"ReviewPhotoSize","Url":"https://photos-us.bazaarvoice.com/photo/2/cGhvdG86c2Ftc3VuZw/48a080cc-681d-5fc3-bccd-61f17182cc94"}}}],"ProductId":"323095575","SubmissionTime":"2025-04-03T22:26:09.000+00:00","TagDimensions":{"__typename":"ReviewsTagDimensions","Pro":null,"Con":null},"Title":"Make sure you don’t plan to side vent your dryer.","TotalNegativeFeedbackCount":0,"TotalPositiveFeedbackCount":0,"ClientResponses":[{"__typename":"ClientResponse","Response":"Hi there, \n\nWe can feel your frustration with this dryer. We are here to help you. \n\nPlease see pages 31 to 33 of the user manual for the complete steps on how to do the side venting. \n\nhttps://downloadcenter.samsung.com/content/UM/202309/20230920202047399/DV6900B_SimpleUX_WEB_Vent_EN_CFR_MES_230915.pdf\n\nShould you still need support, please don’t hesitate to reach out to us through the channels below.\n\n1. Facebook Messenger: http://m.me/samsungsupport\n2. Twitter: https://twitter.com/messages/compose?recipient_id=18768513\n3. Samsung Community: https://us.community.samsung.com/t5/Samsung-Community/ct-p/us\n\nWhen you message us, provide us with this reference number (1148732133), and it will help our team pull up your information.\n\n^Rodel","Date":"2025-04-07T14:54:38.000+00:00","Department":"Samsung Care"}],"Rating":1,"RatingRange":5,"ReviewText":"My poor rating reflects the fact that this model is advertised as having side and bottom venting options and includes a side venting kit on the product page.  HOWEVER, the kit does not work, not even close.  I’m guessing it fits Salmsung’s larger capacity dryers but the kit pieces are way too long for this size dryer.  I’ve had to sit one piece in half with an angle grinder and gerrymander the other pieces to get a half way acceptable side venting.  I guess I shouldn’t be surprised as Samsung as several different sized dryers but only sells one side vent kit.  I can’t believe they haven’t addressed this.","SecondaryRatings":{"__typename":"SecondaryRatings","Quality":null,"Value":{"__typename":"ReviewsQualityRating","Label":"Value","Value":4},"EnergyEfficiency":null,"Features":{"__typename":"ReviewsQualityRating","Label":"Features","Value":1},"Appearance":null,"EaseOfInstallation":null,"EaseOfUse":null},"SecondaryRatingsOrder":["Features","Value"],"SyndicationSource":{"__typename":"SyndicationSource","LogoImageUrl":"https://photos-us.bazaarvoice.com/photo/2/cGhvdG86YXR0cmlidXRpb25sb2dvMg/3f0db944-7f1f-456d-ac37-2291be7453fa","Name":"Samsung US","ContentLink":"https://www.samsung.com/us/laundry/dryers/ventless-4-0-cu-ft-heat-pump-dryer-with-ai-smart-dial-and-wi-fi-connectivity-in-white-sku-dv25b6900ew-a2"},"UserNickname":"travel4b","UserLocation":"Palm Springs, CA","Videos":[],"OriginalProductName":"Front Load Electric Dryer"},{"__typename":"ReviewModel","AuthorId":"zm4m7tm4i50w71oqvrrsdab64o","Badges":{"__typename":"ReviewsBadges","DIY":null,"top250Contributor":null,"IncentivizedReview":null,"EarlyReviewerIncentive":null,"top1000Contributor":null,"VerifiedPurchaser":null},"BadgesOrder":[],"CampaignId":null,"ContextDataValues":{"__typename":"ReviewsContextDataValues","Age":null,"VerifiedPurchaser":null},"ContextDataValuesOrder":[],"Id":"238995117","IsRecommended":false,"IsSyndicated":true,"Photos":[{"__typename":"ReviewPhoto","Id":"12490333","Sizes":{"__typename":"ReviewPhotoSizes","normal":{"__typename":"ReviewPhotoSize","Url":"https://photos-us.bazaarvoice.com/photo/2/cGhvdG86c2Ftc3VuZw/58f585d4-3af8-545a-8fc1-5b9f0bf6a73d"},"thumbnail":{"__typename":"ReviewPhotoSize","Url":"https://photos-us.bazaarvoice.com/photo/2/cGhvdG86c2Ftc3VuZw/00660119-fa9a-5e2f-9c27-87afbed75ee9"}}}],"ProductId":"323095575","SubmissionTime":"2025-01-11T21:39:36.000+00:00","TagDimensions":{"__typename":"ReviewsTagDimensions","Pro":null,"Con":null},"Title":"Would not buy again","TotalNegativeFeedbackCount":0,"TotalPositiveFeedbackCount":0,"ClientResponses":[{"__typename":"ClientResponse","Response":"Hi there,\n\nThe dryer goes hand in hand with your washer. Let's get the information you need to ensure your dryer provides the best performance.\n\nThe links below will help ensure your dryer completes a cycle and guide you in getting dry clothes after each cycle. Please select the scenario that best fits your situation and learn more by watching the embedded video and checking the hyperlinks. \n\nClothes are not dry after using Samsung dryer:\nhttps://www.samsung.com/us/support/troubleshoot/TSG10001001/\n\nHow to clean your Samsung dryer:\nhttps://www.samsung.com/us/support/answer/ANS10001019/\n\nShould you need more assistance with the dryer, please feel free to get back to us via the following options:\n\n1. Facebook Messenger: http://m.me/Samsungsupport\n2. Twitter: https://twitter.com/messages/compose?recipient_id=18768513\n3. Samsung Community: https://us.community.Samsung.com/t5/Samsung-Community/ct-p/us\n\nPlease provide us with this reference number (1148143906) to help our team pull up your information when you message us.\n\nHave a great day.\n\n-Ernest-","Date":"2025-01-13T15:10:19.000+00:00","Department":"SEA Care"}],"Rating":2,"RatingRange":5,"ReviewText":"We've had the similar model without the AI and wifi for over 4 years, purchased at our builder's recommendation as we were building a close to passive house. The various drying programs have frequently stopped short of the time initially indicated on the display and not because the clothes are already dry.  And it takes FOREVER to dry queen and king size sheets, cotton blankets, quilts and duvet covers.  It has always taken a long time but now it is taking up to 2 days for the heavier cotton blankets and flannel duvet covers.  I think this is partially due to the fact that they always ball up during the cycle, even if I put dryer balls, extra towels, tennis balls, etc in the drum, so I have to constantly check the machine, unravel the bedding and start the cycle again.  The heat pump condensor fins came bent (as the dryer had been dropped during delivery, had to have a bottom panel replaced, photo attached to review) and even though I clean the fins after every cycle with the provided brush and also vacuum them periodically, I recently discovered when using a flashlight that they were packed with lint, so I'm sure this has caused the increasingly longer drying times for bedding and the other cycles stopping short of the indicated time.  I just spent over two hours trying to cleaning the condensor fins, got out a lot of lint but there is still lint trapped against the condensor that is impossible to clean.  I don't know why you'd design a key part of the machine that is so difficult to keep clean.  The brush that comes with the machine isn't stiff enough or have long enough bristles to get deep into the fins to get all the lint out.  So I would caution against this machine unless you want to spend the time (and get the right tools) to deep clean the condensor fins after every dryer cycle. I'm sure some (all?) of the issues I have with drying times and cleaning the lint might be due to me not noticing that the heat pump condensor fins were bent when the dryer was delivered but if that is the case I'd say it's a design fault if such a critical component can be damaged during delivery.  So if purchasing this machine, I would definitely check the heat condensor fins upon deiivery and ask for a replacement if the fins are bent.","SecondaryRatings":{"__typename":"SecondaryRatings","Quality":null,"Value":{"__typename":"ReviewsQualityRating","Label":"Value","Value":2},"EnergyEfficiency":null,"Features":{"__typename":"ReviewsQualityRating","Label":"Features","Value":3},"Appearance":null,"EaseOfInstallation":null,"EaseOfUse":null},"SecondaryRatingsOrder":["Features","Value"],"SyndicationSource":{"__typename":"SyndicationSource","LogoImageUrl":"https://photos-us.bazaarvoice.com/photo/2/cGhvdG86YXR0cmlidXRpb25sb2dvMg/3f0db944-7f1f-456d-ac37-2291be7453fa","Name":"Samsung US","ContentLink":"https://www.samsung.com/us/laundry/dryers/ventless-4-0-cu-ft-heat-pump-dryer-with-ai-smart-dial-and-wi-fi-connectivity-in-white-sku-dv25b6900hw-a2"},"UserNickname":"KA in VA","UserLocation":"Shenandoah Valley, VA","Videos":[],"OriginalProductName":"Front Load Ventless Heat Pump Dryer"},{"__typename":"ReviewModel","AuthorId":"0114685944","Badges":{"__typename":"ReviewsBadges","DIY":null,"top250Contributor":null,"IncentivizedReview":null,"EarlyReviewerIncentive":null,"top1000Contributor":null,"VerifiedPurchaser":null},"BadgesOrder":["verifiedPurchaser"],"CampaignId":null,"ContextDataValues":{"__typename":"ReviewsContextDataValues","Age":null,"VerifiedPurchaser":null},"ContextDataValuesOrder":[],"Id":"283396433","IsRecommended":false,"IsSyndicated":true,"Photos":[{"__typename":"ReviewPhoto","Id":"14449050","Sizes":{"__typename":"ReviewPhotoSizes","normal":{"__typename":"ReviewPhotoSize","Url":"https://photos-us.bazaarvoice.com/photo/2/cGhvdG86aG9tZWRlcG90LWNhbmFkYQ/8046ed54-0317-5663-916a-5a46fd117a45"},"thumbnail":{"__typename":"ReviewPhotoSize","Url":"https://photos-us.bazaarvoice.com/photo/2/cGhvdG86aG9tZWRlcG90LWNhbmFkYQ/9c7d0d86-c6ba-51ee-96f3-0e5aefd53671"}}}],"ProductId":"323095575","SubmissionTime":"2024-07-31T22:43:22.000+00:00","TagDimensions":{"__typename":"ReviewsTagDimensions","Pro":null,"Con":null},"Title":"LG Dryer","TotalNegativeFeedbackCount":0,"TotalPositiveFeedbackCount":0,"ClientResponses":[],"Rating":3,"RatingRange":5,"ReviewText":"I bought LG Washer and Dryer as a set. Color white. But the color of Dryer changed to off-white. The cloths do not dry well. I had to rerun the dryer.","SecondaryRatings":{"__typename":"SecondaryRatings","Quality":null,"Value":null,"EnergyEfficiency":null,"Features":null,"Appearance":null,"EaseOfInstallation":null,"EaseOfUse":null},"SecondaryRatingsOrder":[],"SyndicationSource":{"__typename":"SyndicationSource","LogoImageUrl":"https://photos-us.bazaarvoice.com/photo/2/cGhvdG86YXR0cmlidXRpb25sb2dvMg/bd3baf16-5d94-4bc3-80bf-9271f978257d","Name":"homedepot.ca","ContentLink":"https://www.homedepot.ca/product/samsung-4-0-cu-ft-electric-dryer-with-sensor-dry-smart-care-and-ai-smart-dial-in-white-stackable-energy-star-/1001768710"},"UserNickname":"Laxman","UserLocation":null,"Videos":[],"OriginalProductName":"4.0 cu.ft. Electric Dryer with Sensor Dry, Smart Care and AI Smart Dial in White, Stackable - ENERGY STAR®"},{"__typename":"ReviewModel","AuthorId":"ti_4403480","Badges":{"__typename":"ReviewsBadges","DIY":null,"top250Contributor":null,"IncentivizedReview":null,"EarlyReviewerIncentive":null,"top1000Contributor":null,"VerifiedPurchaser":null},"BadgesOrder":[],"CampaignId":null,"ContextDataValues":{"__typename":"ReviewsContextDataValues","Age":{"__typename":"ReviewsContextDataValue","Value":"25to34"},"VerifiedPurchaser":null},"ContextDataValuesOrder":["Age","Gender"],"Id":"223628425","IsRecommended":true,"IsSyndicated":true,"Photos":[{"__typename":"ReviewPhoto","Id":"7425866","Sizes":{"__typename":"ReviewPhotoSizes","normal":{"__typename":"ReviewPhotoSize","Url":"https://photos-us.bazaarvoice.com/photo/2/cGhvdG86c2Ftc3VuZw/dbd1874d-fe6d-5422-afc6-129a8007fe2d"},"thumbnail":{"__typename":"ReviewPhotoSize","Url":"https://photos-us.bazaarvoice.com/photo/2/cGhvdG86c2Ftc3VuZw/ec5fb04f-1002-53e6-88d2-12f69a442d4a"}}},{"__typename":"ReviewPhoto","Id":"7425867","Sizes":{"__typename":"ReviewPhotoSizes","normal":{"__typename":"ReviewPhotoSize","Url":"https://photos-us.bazaarvoice.com/photo/2/cGhvdG86c2Ftc3VuZw/dadde1e9-a081-5b14-8fb2-6f6fd807308f"},"thumbnail":{"__typename":"ReviewPhotoSize","Url":"https://photos-us.bazaarvoice.com/photo/2/cGhvdG86c2Ftc3VuZw/0423cdfc-90c6-55b1-bf24-88e823e96d44"}}},{"__typename":"ReviewPhoto","Id":"7425868","Sizes":{"__typename":"ReviewPhotoSizes","normal":{"__typename":"ReviewPhotoSize","Url":"https://photos-us.bazaarvoice.com/photo/2/cGhvdG86c2Ftc3VuZw/67a9c054-b6b6-5959-ba15-83b0ef627894"},"thumbnail":{"__typename":"ReviewPhotoSize","Url":"https://photos-us.bazaarvoice.com/photo/2/cGhvdG86c2Ftc3VuZw/7b147d28-6824-53ce-a7d8-7092e6c5a72d"}}}],"ProductId":"323095575","SubmissionTime":"2023-02-22T16:36:10.000+00:00","TagDimensions":{"__typename":"ReviewsTagDimensions","Pro":null,"Con":null},"Title":"Smart Dryer","TotalNegativeFeedbackCount":0,"TotalPositiveFeedbackCount":0,"ClientResponses":[],"Rating":4,"RatingRange":5,"ReviewText":"[This review was collected as part of a promotion.] I love the style of this dryer, but I thought the door would be more transparent. It is barely transparent but it has a light that you can turn on while in use. Since this is an energy saving dryer, it takes longer to dry things which I had to get used to since my last dryer was not energy efficient. I really like all the different cycles it has. Using a cycle in relation to the type of fabric I am using has really restored the quality of the fabrics. I am amazed! The Smart Things app is a great feature but it needs some updates. For example, I can't see how long a load is going to take before starting the cycle, I can't turn my dryer on or off my with it, etc. There was no instructions on where to drain the vent but I figured it out after my dryer stopped working. It is in the same spot you would put your detergent in the washer. The dryer is advertised as quiet but I think it sounds like the average dryer. My dryer door opens up in the same direction as my washer door which I don't like and I'm hoping can be reversed. I don't have mine stacked. The pros definitely outweigh the cons though. I am very happy to do my laundry with this dryer. I am still exploring new and better ways to do my laundry with it.","SecondaryRatings":{"__typename":"SecondaryRatings","Quality":null,"Value":null,"EnergyEfficiency":null,"Features":null,"Appearance":null,"EaseOfInstallation":null,"EaseOfUse":null},"SecondaryRatingsOrder":[],"SyndicationSource":{"__typename":"SyndicationSource","LogoImageUrl":"https://contentorigin.bazaarvoice.com/theinsiders/default/C19_Insiders_PeopleTrustPeople_Logo_Grey.png","Name":"The Insiders","ContentLink":null},"UserNickname":"swaggygabby","UserLocation":"Janesville","Videos":[],"OriginalProductName":"Front Load Ventless Heat Pump Dryer"},{"__typename":"ReviewModel","AuthorId":"zmfd0acrj4exywvx3thqe81mvf","Badges":{"__typename":"ReviewsBadges","DIY":null,"top250Contributor":null,"IncentivizedReview":null,"EarlyReviewerIncentive":null,"top1000Contributor":null,"VerifiedPurchaser":null},"BadgesOrder":[],"CampaignId":null,"ContextDataValues":{"__typename":"ReviewsContextDataValues","Age":null,"VerifiedPurchaser":null},"ContextDataValuesOrder":[],"Id":"223623856","IsRecommended":true,"IsSyndicated":true,"Photos":[{"__typename":"ReviewPhoto","Id":"7424249","Sizes":{"__typename":"ReviewPhotoSizes","normal":{"__typename":"ReviewPhotoSize","Url":"https://photos-us.bazaarvoice.com/photo/2/cGhvdG86c2Ftc3VuZw/af26ff9c-a1b8-5f5c-848a-f7076602f93a"},"thumbnail":{"__typename":"ReviewPhotoSize","Url":"https://photos-us.bazaarvoice.com/photo/2/cGhvdG86c2Ftc3VuZw/33b8ea33-1aa8-53a6-8fa8-5eb52f613623"}}},{"__typename":"ReviewPhoto","Id":"7424250","Sizes":{"__typename":"ReviewPhotoSizes","normal":{"__typename":"ReviewPhotoSize","Url":"https://photos-us.bazaarvoice.com/photo/2/cGhvdG86c2Ftc3VuZw/aa685d76-2dbf-5e21-be73-a3ddea0c4d11"},"thumbnail":{"__typename":"ReviewPhotoSize","Url":"https://photos-us.bazaarvoice.com/photo/2/cGhvdG86c2Ftc3VuZw/9bf43a68-e2db-509c-ba9e-340ce5b2e405"}}},{"__typename":"ReviewPhoto","Id":"7424251","Sizes":{"__typename":"ReviewPhotoSizes","normal":{"__typename":"ReviewPhotoSize","Url":"https://photos-us.bazaarvoice.com/photo/2/cGhvdG86c2Ftc3VuZw/a33f62dd-4c19-5b2d-b8ea-0d5cfb6636ec"},"thumbnail":{"__typename":"ReviewPhotoSize","Url":"https://photos-us.bazaarvoice.com/photo/2/cGhvdG86c2Ftc3VuZw/54c5159c-c468-5baf-a1d1-3ab7e159299b"}}}],"ProductId":"323095575","SubmissionTime":"2023-02-22T10:06:38.000+00:00","TagDimensions":{"__typename":"ReviewsTagDimensions","Pro":null,"Con":null},"Title":"Smart Dryer","TotalNegativeFeedbackCount":0,"TotalPositiveFeedbackCount":0,"ClientResponses":[],"Rating":4,"RatingRange":5,"ReviewText":"I love the style of this dryer, but I thought the door would be more transparent. It is barely transparent but it has a light that you can turn on while in use. Since this is an energy saving dryer, it takes longer to dry things which I had to get used to since my last dryer was not energy efficient. I really like all the different cycles it has. Using a cycle in relation to the type of fabric I am using has really restored the quality of the fabrics. I am amazed! The Smart Things app is a great feature but it needs some updates. For example, I can't see how long a load is going to take before starting the cycle, I can't turn my dryer on or off my with it, etc. There was no instructions on where to drain the vent but I figured it out after my dryer stopped working. It is in the same spot you would put your detergent in the washer. The dryer is advertised as quiet but I think it sounds like the average dryer. My dryer door opens up in the same direction as my washer door which I don't like and I'm hoping can be reversed. I don't have mine stacked. The pros definitely outweigh the cons though. I am very happy to do my laundry with this dryer. I am still exploring new and better ways to do my laundry with it.","SecondaryRatings":{"__typename":"SecondaryRatings","Quality":null,"Value":{"__typename":"ReviewsQualityRating","Label":"Value","Value":4},"EnergyEfficiency":null,"Features":{"__typename":"ReviewsQualityRating","Label":"Features","Value":5},"Appearance":null,"EaseOfInstallation":null,"EaseOfUse":null},"SecondaryRatingsOrder":["Features","Value"],"SyndicationSource":{"__typename":"SyndicationSource","LogoImageUrl":"https://photos-us.bazaarvoice.com/photo/2/cGhvdG86YXR0cmlidXRpb25sb2dvMg/3f0db944-7f1f-456d-ac37-2291be7453fa","Name":"Samsung US","ContentLink":"https://www.samsung.com/us/laundry/dryers/ventless-4-0-cu-ft-heat-pump-dryer-with-ai-smart-dial-and-wi-fi-connectivity-in-white-sku-dv25b6900hw-a2"},"UserNickname":"Gabby","UserLocation":"Janesville, WI","Videos":[],"OriginalProductName":"Front Load Ventless Heat Pump Dryer"}],"Includes":{"__typename":"ReviewIncludes","Products":{"__typename":"ReviewIncludesProducts","store":{"__typename":"ReviewProductDataStore","Id":"323095575","FilteredReviewStatistics":{"__typename":"ReviewsFilteredReviewStatistics","AverageOverallRating":"3.9","TotalReviewCount":86,"RecommendedCount":27,"NotRecommendedCount":16,"SecondaryRatingsAveragesOrder":["Quality","Value"],"RatingDistribution":[{"__typename":"RatingDistribution","RatingValue":5,"Count":48},{"__typename":"RatingDistribution","RatingValue":4,"Count":16},{"__typename":"RatingDistribution","RatingValue":3,"Count":3},{"__typename":"RatingDistribution","RatingValue":2,"Count":3},{"__typename":"RatingDistribution","RatingValue":1,"Count":16}],"ContextDataDistribution":{"__typename":"ContextDataDistributions","Age":{"__typename":"ContextDataDistribution","Values":[{"__typename":"ContextDataDistributionValue","Value":"18to24","Count":"0"},{"__typename":"ContextDataDistributionValue","Value":"25to34","Count":"1"},{"__typename":"ContextDataDistributionValue","Value":"35to44","Count":"6"},{"__typename":"ContextDataDistributionValue","Value":"45to54","Count":"1"},{"__typename":"ContextDataDistributionValue","Value":"55to64","Count":"4"},{"__typename":"ContextDataDistributionValue","Value":"65orOver","Count":"0"}]},"Gender":{"__typename":"ContextDataDistribution","Values":[{"__typename":"ContextDataDistributionValue","Value":"Male","Count":"5"},{"__typename":"ContextDataDistributionValue","Value":"Female","Count":"7"}]},"Expertise":null,"VerifiedPurchaser":{"__typename":"ContextDataDistribution","Values":[{"__typename":"ContextDataDistributionValue","Value":"True","Count":"40"}]},"HomeGoodsProfile":{"__typename":"ContextDataDistribution","Values":[{"__typename":"ContextDataDistributionValue","Value":"DIYer","Count":"0"},{"__typename":"ContextDataDistributionValue","Value":"Professional","Count":"0"}]}},"TotalRecommendedCount":43}},"items":[]}},"FilterSelected":{"__typename":"BVReviewFilter","StarRatings":null,"VerifiedPurchaser":null,"SearchText":null},"pagination":{"__typename":"BVPagination","previousPage":null,"pages":[{"__typename":"BVPage","label":"1","isNextPage":null,"isPreviousPage":null,"isSelectedPage":true},{"__typename":"BVPage","label":"2","isNextPage":null,"isPreviousPage":null,"isSelectedPage":false},{"__typename":"BVPage","label":null,"isNextPage":null,"isPreviousPage":null,"isSelectedPage":false},{"__typename":"BVPage","label":"9","isNextPage":null,"isPreviousPage":null,"isSelectedPage":false}],"nextPage":{"__typename":"BVPage","label":"2","isNextPage":true,"isPreviousPage":null,"isSelectedPage":false}},"SortBy":{"__typename":"BVSortBy","mosthelpfull":null,"newest":null,"oldest":null,"highestrating":null,"lowestrating":null,"photoreview":true},"TotalResults":86},"component({\"componentClass\":\"PlccInlineComponent\",\"id\":\"3ekAMR8magFrikkcOhyH2h\"})":{"__ref":"PlccInlineComponent:3ekAMR8magFrikkcOhyH2h"},"emtContent({\"contentId\":\"323095575\",\"pageName\":\"pip\"})":{"__typename":"EmtContent","content":{"metadata":null,"productGroup":null}},"product:{\"itemId\":\"323095575\"}":{"__ref":"base-catalog-323095575"},"questionsAnswers({\"itemId\":\"323095575\",\"pagesize\":8,\"searchTerm\":\"\",\"sortBy\":\"newest\",\"startindex\":1})":{"__typename":"QAResponse","TotalResults":46,"Includes":{"__typename":"Includes","Answers":[{"__typename":"AnswerIncludes","AnswerId":"15194755","Answer":{"__typename":"Answer","Id":"15194755","AnswerText":"Hi Mariann,\n\nNo, connecting this dryer model to your phone is optional if you want to use the smart control features. After connecting the Tumble Dryer to your home network using the SmartThings app, you can control or monitor the dryer remotely.\n\nHave a wonderful day.\n\n-Kimberly","AuthorId":"BRAND_ANSWERS_Samsung","CampaignId":"BV_QA_BRAND_ANSWERS","LastModeratedTime":"2026-02-17T21:45:14.000+00:00","LastModificationTime":"2026-02-17T21:45:14.000+00:00","ModerationStatus":"APPROVED","UserNickname":"Samsung","IsFeatured":false,"IsBrandAnswer":true,"BadgesOrder":[],"TotalPositiveFeedbackCount":0,"Photos":[]}},{"__typename":"AnswerIncludes","AnswerId":"14845787","Answer":{"__typename":"Answer","Id":"14845787","AnswerText":"Hi Greg,\n\nWe're happy to answer your question about this Samsung dryer model.\n\nThis dryer requires 240 volts, 60 Hz frequency, and 30 amperes to operate.\n\nLeo","AuthorId":"BRAND_ANSWERS_Samsung","CampaignId":"BV_QA_BRAND_ANSWERS","LastModeratedTime":"2025-07-17T22:15:09.000+00:00","LastModificationTime":"2025-07-17T22:15:09.000+00:00","ModerationStatus":"APPROVED","UserNickname":"Samsung","IsFeatured":false,"IsBrandAnswer":true,"BadgesOrder":[],"TotalPositiveFeedbackCount":0,"Photos":[]}},{"__typename":"AnswerIncludes","AnswerId":"15215478","Answer":{"__typename":"Answer","Id":"15215478","AnswerText":"Hi Winnie,\n\nYes, this Front Load Electric Dryer is a vented unit. Heat pump dryers are generally more energy efficient, but they may take longer to dry clothes compared to conventional vented dryers. The model Samsung DV25B6900HW is an example of a ventless unit.\n\n-Diana","AuthorId":"BRAND_ANSWERS_Samsung","CampaignId":"BV_QA_BRAND_ANSWERS","LastModeratedTime":"2026-03-02T23:45:07.000+00:00","LastModificationTime":"2026-03-25T18:59:50.000+00:00","ModerationStatus":"APPROVED","UserNickname":"Samsung","IsFeatured":false,"IsBrandAnswer":true,"BadgesOrder":[],"TotalPositiveFeedbackCount":1,"Photos":[]}},{"__typename":"AnswerIncludes","AnswerId":"15063331","Answer":{"__typename":"Answer","Id":"15063331","AnswerText":"Hi Elisha,\n\nYes, this Samsung dryer model will fit your space. Your recessed area is 27.5 inches deep and more than 36 inches wide (3+ feet), which meets the installation requirements. It will also fit as long as the available height is more than 33 1/2 inches. The carpet beyond the 27.5-inch depth will not affect the fitment as long as the dryer sits fully within the recessed hard-surface area.\n\nThis dryer does support side venting when used with the side-vent kit model DV-2A, which is sold separately, so it can accommodate hookups on the left wall.\n\nLeo","AuthorId":"BRAND_ANSWERS_Samsung","CampaignId":"BV_QA_BRAND_ANSWERS","LastModeratedTime":"2025-11-24T20:15:05.000+00:00","LastModificationTime":"2025-11-24T20:15:05.000+00:00","ModerationStatus":"APPROVED","UserNickname":"Samsung","IsFeatured":false,"IsBrandAnswer":true,"BadgesOrder":[],"TotalPositiveFeedbackCount":0,"Photos":[]}},{"__typename":"AnswerIncludes","AnswerId":"14859950","Answer":{"__typename":"Answer","Id":"14859950","AnswerText":"Hi Greg,\n\nWe're glad to help answer your question about this Samsung dryer model.\n\nThe electric dryer operates at 240 volts, 60 Hz, and requires a 30-amp circuit.\n\nLeo","AuthorId":"BRAND_ANSWERS_Samsung","CampaignId":"BV_QA_BRAND_ANSWERS","LastModeratedTime":"2025-07-25T18:45:06.000+00:00","LastModificationTime":"2025-07-25T18:45:06.000+00:00","ModerationStatus":"APPROVED","UserNickname":"Samsung","IsFeatured":false,"IsBrandAnswer":true,"BadgesOrder":[],"TotalPositiveFeedbackCount":0,"Photos":[]}},{"__typename":"AnswerIncludes","AnswerId":"15087145","Answer":{"__typename":"Answer","Id":"15087145","AnswerText":"Greetings,\n\nThe model of your washer and dryer combo was needed for us to check if it can be vented.\n\nPlease feel free to reach us via the options below, as we look forward to assisting you in the best possible way.\n\n1. Facebook Messenger: http://m.me/samsungsupport  \n2. Twitter: https://twitter.com/messages/compose?recipient_id=18768513  \n3. Samsung Community: https://us.commuity.samsung.com/t5/Samsung-Community/ct-p/us   \n \nPlease provide us with this reference number (1151525310) to help our team pull up your information when you message us.  \n \nThank you.\n \n-Ricardo","AuthorId":"BRAND_ANSWERS_Samsung","CampaignId":"BV_QA_BRAND_ANSWERS","LastModeratedTime":"2025-12-09T01:30:06.000+00:00","LastModificationTime":"2025-12-09T01:30:06.000+00:00","ModerationStatus":"APPROVED","UserNickname":"Samsung","IsFeatured":false,"IsBrandAnswer":true,"BadgesOrder":[],"TotalPositiveFeedbackCount":0,"Photos":[]}},{"__typename":"AnswerIncludes","AnswerId":"15175634","Answer":{"__typename":"Answer","Id":"15175634","AnswerText":"Hi Annette,\n\nNo, the back of the dryer cannot be removed. Please refer to pages 31-33 of the manual link below for guidelines on installing a side vent without removing the back cover of the dryer.\n\nUser manual\nhttps://downloadcenter.samsung.com/content/UM/202309/20230920202047399/DV6900B_SimpleUX_WEB_Vent_EN_CFR_MES_230915.pdf\n\nHave a wonderful day.\n\n-Kimberly","AuthorId":"BRAND_ANSWERS_Samsung","CampaignId":"BV_QA_BRAND_ANSWERS","LastModeratedTime":"2026-02-03T22:30:07.000+00:00","LastModificationTime":"2026-02-03T22:30:07.000+00:00","ModerationStatus":"APPROVED","UserNickname":"Samsung","IsFeatured":false,"IsBrandAnswer":true,"BadgesOrder":[],"TotalPositiveFeedbackCount":0,"Photos":[]}},{"__typename":"AnswerIncludes","AnswerId":"14825221","Answer":{"__typename":"Answer","Id":"14825221","AnswerText":"Hi Mary,\n\nNo, the Samsung model DV25B6900** is only available as an electric and heat pump dryer. It is not available as a gas dryer.\n\nLeo","AuthorId":"BRAND_ANSWERS_Samsung","CampaignId":"BV_QA_BRAND_ANSWERS","LastModeratedTime":"2025-07-07T19:45:08.000+00:00","LastModificationTime":"2025-07-07T19:45:08.000+00:00","ModerationStatus":"APPROVED","UserNickname":"Samsung","IsFeatured":false,"IsBrandAnswer":true,"BadgesOrder":[],"TotalPositiveFeedbackCount":0,"Photos":[]}}],"AnswersOrder":["15063331","14859950","15194755","15175634","14825221","14845787","15087145","15215478"]},"Limit":8,"Offset":0,"Results":[{"__typename":"QAModel","Id":"11062181","AuthorId":"0513E14752D78C3D0U","AnswerIds":["15215478"],"TotalAnswerCount":1,"QuestionSummary":"Is this item vented or ventless? The reviews complain about the \"water tank\" and that ventless dryer takes a long time, however the Home Depot description says it is vented. Which is it?","QuestionDetails":null,"SubmissionTime":"2026-03-01T20:17:16.000+00:00","UserNickname":"Winnie","SubmissionId":"r11999_17723962GJs8bdVffa","Photos":[]},{"__typename":"QAModel","Id":"11032935","AuthorId":"mo5qmmss2uc91c02d77efg3g3","AnswerIds":["15194755"],"TotalAnswerCount":1,"QuestionSummary":"Do you have to hook the smart dryer to your phone","QuestionDetails":null,"SubmissionTime":"2026-02-14T20:55:21.000+00:00","UserNickname":"Mariann","SubmissionId":"r11999_17711025B55cWY9e3R","Photos":[]},{"__typename":"QAModel","Id":"11010713","AuthorId":"0513E0A4C59139300U","AnswerIds":["15175634"],"TotalAnswerCount":1,"QuestionSummary":"Can the back be removed for re-routing the exhaust vent to the left side? I don't see how this can be done without removing the back, since an elbow needs to be secured inside.","QuestionDetails":null,"SubmissionTime":"2026-02-02T17:14:52.000+00:00","UserNickname":"Annette","SubmissionId":"r11999_17700524FAAGV9aZBY","Photos":[]},{"__typename":"QAModel","Id":"10902059","AuthorId":"5tyqcmckus9mgfmwmpz331fe5","AnswerIds":["15087145"],"TotalAnswerCount":1,"QuestionSummary":"I have the Samsung washer dryercombination. I don’t like the ventless that I have can I make it vented like my last dryer","QuestionDetails":null,"SubmissionTime":"2025-12-05T02:00:26.000+00:00","UserNickname":"Samsung","SubmissionId":"r11999_17649000lWxgav2g63","Photos":[]},{"__typename":"QAModel","Id":"10874469","AuthorId":"h58c6jculyaao439m8wo9qtyj","AnswerIds":["15063331"],"TotalAnswerCount":1,"QuestionSummary":"I have a 27.5 recessed space that is 3+ feet wide. Beyond 27.5 depth it is carpet. The hookups are on the left wall. Does this dryer have side venting, and would it fit in my space for install?","QuestionDetails":null,"SubmissionTime":"2025-11-22T21:12:22.000+00:00","UserNickname":"Elisha","SubmissionId":"r11999_17638459oftkI77Zuo","Photos":[]},{"__typename":"QAModel","Id":"10626370","AuthorId":"0527A37915604AB60U","AnswerIds":["14859950"],"TotalAnswerCount":1,"QuestionSummary":"110 or 240 volt","QuestionDetails":null,"SubmissionTime":"2025-07-25T16:59:02.000+00:00","UserNickname":"Greg","SubmissionId":"r11999_175346273ey4PBtV6q","Photos":[]},{"__typename":"QAModel","Id":"10609112","AuthorId":"0527A37915604AB60U","AnswerIds":["14845787"],"TotalAnswerCount":1,"QuestionSummary":"Voltage","QuestionDetails":null,"SubmissionTime":"2025-07-17T15:05:50.000+00:00","UserNickname":"Greg","SubmissionId":"r11999_175276471PM8C6c9ux","Photos":[]},{"__typename":"QAModel","Id":"10578333","AuthorId":"5wfy2j8plomanjfg990q4uf1o","AnswerIds":["14825221"],"TotalAnswerCount":1,"QuestionS