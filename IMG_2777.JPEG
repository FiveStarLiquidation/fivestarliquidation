imensionName":"Category","label":"Electric Dryers","refinementKey":null,"url":"/b/Appliances-Washers-Dryers-Dryers-Electric-Dryers/N-5yc1vZc3q1"}],"brandLinkUrl":"/b/Appliances-Washers-Dryers-Dryers-Electric-Dryers/Samsung/N-5yc1vZc3q1Za0f"},"dataSource":"catalog","info":{"__typename":"Info","label":null,"isSponsored":null,"sponsoredMetadata":null,"sponsoredBeacon":null,"productSubType":null,"augmentedReality":false,"globalCustomConfigurator":null,"isLiveGoodsProduct":false,"hidePrice":false,"ecoRebate":true,"quantityLimit":0,"categoryHierarchy":null,"sskMin":null,"sskMax":null,"unitOfMeasureCoverage":null,"wasMaxPriceRange":null,"wasMinPriceRange":null,"gccExperienceOmsId":null,"dotComColorEligible":false,"productDepartment":"29","classNumber":"8","isGenericProduct":null,"customerSignal":null,"isBuryProduct":null,"returnable":"Non-Returnable","hasSubscription":false,"swatches":null,"totalNumberOfOptions":null,"replacementOMSID":null,"subClassNumber":"7","hasVisuallySimilar":false,"paintBrand":null,"paintFamily":null,"displayWhatWeOffer":true,"prop65Warning":true,"prop65Message":"CALIFORNIA RESIDENTS ONLY - Cancer and Reproductive Harm - www.P65Warnings.ca.gov"},"badges({\"storeId\":\"8119\"})":[],"pricing({\"isBrandPricingPolicyCompliant\":false,\"storeId\":\"8119\"})":{"__typename":"Pricing","message":null,"original":1099,"mapAboveOriginalPrice":null,"promotion":{"__typename":"Promotion","dollarOff":110,"type":"DISCOUNT","description":null,"percentageOff":10,"promotionTag":null,"savingsCenter":null,"savingsCenterPromos":null,"specialBuySavings":null,"specialBuyDollarOff":null,"specialBuyPercentageOff":null,"dates":{"__typename":"Dates","end":"04/29/2026","start":"04/09/2026"},"experienceTag":null,"subExperienceTag":null},"value":989,"alternatePriceDisplay":false,"alternate":{"__typename":"Alternate","bulk":null,"unit":{"__typename":"UnitPricing","caseUnitOfMeasure":null,"unitsOriginalPrice":null,"unitsPerCase":null,"value":null}},"mapDetail":null,"preferredPriceFlag":false,"specialBuy":null,"unitOfMeasure":"each","clearance":null,"conditionalPromotions":null},"reviews":{"__typename":"Reviews","ratingsReviews":{"__typename":"RatingsReviews","totalReviews":"86","averageRating":"3.8953"}},"details":{"__typename":"Details","collection":null,"installation":{"__typename":"Installation","serviceType":"PRInstall"},"description":"Samsung's 4.0 cu. ft. Large Capacity Electric Dryer is equipped with our AI Smart Dial, which learns and recommends your favorite cycles and simplifies the control panel to make controlling your dryer a breeze. It is also Wi-Fi Connected, so you can get end of cycle alerts, remotely start, schedule and more from your smartphone with the SmartThings App.","highlights":["Large 4.0 cu. ft. capacity","Pairs best with WW25B6900AW washer","Easy to use, AI smart dial simplifies your dryer’s control panel"],"descriptiveAttributes":[{"__typename":"DescriptiveAttribute","name":"Bullet01","value":"Samsung's easy to use, AI Smart Dial simplifies your dryer's control panel, learns and recommends your favorite cycles, and allows you to customize your cycle list, making laundry day a breeze.","bulleted":true,"sequence":0},{"__typename":"DescriptiveAttribute","name":"Bullet02","value":"Wi-Fi connected so you can receive end of cycle alerts, remotely start or stop your drying, schedule cycles on your time, and more, right from your smartphone with the SmartThings App.²","bulleted":true,"sequence":0},{"__typename":"DescriptiveAttribute","name":"Bullet03","value":"Automatically optimizes the time and temperature of your drying cycle to protect your clothes from heat damage, while avoiding excess energy use.","bulleted":true,"sequence":0},{"__typename":"DescriptiveAttribute","name":"Bullet04","value":"Conveniently designed to fit your space without sacrificing capacity.","bulleted":true,"sequence":0},{"__typename":"DescriptiveAttribute","name":"Bullet05","value":"With its compact profile, this dryer is designed for easy closet installation, without sacrificing capacity.³","bulleted":true,"sequence":0},{"__typename":"DescriptiveAttribute","name":"Bullet06","value":"Worry less about lint or fluff blocking the dryer's air intake. The control panel provides a helpful reminder to clean the filter to keep your dryer running smoothly.","bulleted":true,"sequence":0},{"__typename":"DescriptiveAttribute","name":"Bullet07","value":"Keep your dryer looking like new with a durable stainless steel drum that helps prevent nicks and scratches.","bulleted":true,"sequence":0},{"__typename":"DescriptiveAttribute","name":"Bullet08","value":"An internal drum light lets you see the contents of your dryer more clearly, meaning fewer missed socks or small items.","bulleted":true,"sequence":0},{"__typename":"DescriptiveAttribute","name":"Bullet09","value":"Install your washer and dryer stacked or side by side to fit any space.","bulleted":true,"sequence":0},{"__typename":"DescriptiveAttribute","name":"Bullet10","value":"Choose which way your dryer door opens to better suit your laundry room layout.","bulleted":true,"sequence":0},{"__typename":"DescriptiveAttribute","name":"Bullet11","value":"Samsung washers and dryers team up to make light work of laundry day.","bulleted":true,"sequence":0},{"__typename":"DescriptiveAttribute","name":"Bullet12","value":"AI Smart Dial makes recommendations within 30 days of use based on cycle selections, time selected, and other factors.","bulleted":true,"sequence":0},{"__typename":"DescriptiveAttribute","name":"Bullet13","value":"²Requires wireless network, Samsung account and SmartThings App. The Samsung SmartThings App supports Android OS 4.0 (ICS) or later which is optimized for Samsung smartphones (Galaxy S and Galaxy Note series). This app also supports iOS 7 or later for iPhone models. SmartThings App available in App Store and Play Store. Only monitoring enabled on Gas Dryers for safety reasons.","bulleted":true,"sequence":0},{"__typename":"DescriptiveAttribute","name":"Bullet14","value":"³Designed to fit a 30\" installation depth.","bulleted":true,"sequence":0},{"__typename":"DescriptiveAttribute","name":"Bullet20","value":"\u003ca href=\"https://www.homedepot.com/b/Appliances/Samsung/N-5yc1vZbv1wZa0f\" target=\"_blank\" style=\"color:#F96302;\">Click here to shop more Samsung appliances\u003c/a>","bulleted":true,"sequence":0},{"__typename":"DescriptiveAttribute","name":"Bullet23","value":"\u003ca href=\"https://www.homedepot.com/c/electronics_recycling_programs\" style=\"color:#F96302;\" target=\"_blank\">Click here for more information on Electronic Recycling Programs\u003c/a>","bulleted":true,"sequence":0}],"additionalResources":{"__typename":"AdditionalResources","infoAndGuides":[{"__typename":"AdditionalResourceDetails","name":"SDS","url":"https://images.thdstatic.com/catalog/pdfImages/NR/NR"},{"__typename":"AdditionalResourceDetails","name":"Specification","url":"https://images.thdstatic.com/catalog/pdfImages/3a/3a77180c-0fb8-4e0b-9487-878607d4952d.pdf"},{"__typename":"AdditionalResourceDetails","name":"Warranty","url":"https://images.thdstatic.com/catalog/pdfImages/c8/c83e5e83-75e3-41df-92b0-6114be504715.pdf"},{"__typename":"AdditionalResourceDetails","name":"Compatibility Chart","url":"https://images.thdstatic.com/catalog/pdfImages/62/623c2542-3173-4a2f-85a2-e32a203d943a.pdf"},{"__typename":"AdditionalResourceDetails","name":"Installation Guide","url":"https://images.thdstatic.com/catalog/pdfImages/7d/7da7c2e1-5c31-401c-aa23-fa4ffb7a1aa5.pdf"},{"__typename":"AdditionalResourceDetails","name":"Use and Care Manual","url":"https://images.thdstatic.com/catalog/pdfImages/d5/d5983dce-7fce-4f90-8160-4e3de274c9f5.pdf"}],"installationAndRentals":[],"diyProjects":[]}},"specificationGroup":[{"__typename":"SpecificationGroup","specTitle":"Details","specifications":[{"__typename":"Specification","specName":"Amperage (A)","specValue":"30 A"},{"__typename":"Specification","specName":"Appliance Category","specValue":"Dryer"},{"__typename":"Specification","specName":"Appliance Series","specValue":"Not Applicable"},{"__typename":"Specification","specName":"Appliance Type","specValue":"Electric Dryer"},{"__typename":"Specification","specName":"Capacity - Dryer (cu. ft.)","specValue":"4.0"},{"__typename":"Specification","specName":"Color/Finish","specValue":"White"},{"__typename":"Specification","specName":"Color/Finish Family","specValue":"White"},{"__typename":"Specification","specName":"Dryer Features","specValue":"Interior Light,Lint Filter,Sensor Dry,Timed Dry,Wi-Fi Enabled"},{"__typename":"Specification","specName":"Dryer Fuel Type","specValue":"Electric"},{"__typename":"Specification","specName":"Matching Washer Type","specValue":"Front Load Matching"},{"__typename":"Specification","specName":"Pedestal Model#","specValue":"NA"},{"__typename":"Specification","specName":"Product Weight (lb.)","specValue":"88.4 lb"},{"__typename":"Specification","specName":"Returnable","specValue":"Non-Returnable"},{"__typename":"Specification","specName":"Stackable","specValue":"Stackable"},{"__typename":"Specification","specName":"Stacking Kit Model#","specValue":"SK-DH"},{"__typename":"Specification","specName":"Vent Type","specValue":"Vented"},{"__typename":"Specification","specName":"Voltage (volts)","specValue":"240"}]},{"__typename":"SpecificationGroup","specTitle":"Warranty / Certifications","specifications":[{"__typename":"Specification","specName":"Certifications and Listings","specValue":"No Certifications or Listings"},{"__typename":"Specification","specName":"Manufacturer Warranty","specValue":"One (1) Year Parts and Labor"}]},{"__typename":"SpecificationGroup","specTitle":"Dimensions","specifications":[{"__typename":"Specification","specName":"Depth With Door Open 90 Degrees (in.)","specValue":"43.3 in"},{"__typename":"Specification","specName":"Product Depth (in.)","specValue":"25.81 in"},{"__typename":"Specification","specName":"Product Height (in.)","specValue":"33.5 in"},{"__typename":"Specification"